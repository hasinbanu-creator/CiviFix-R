<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="CiviFix Enterprise Automation Suite" parallel="none">
    <listeners>
        <listener class-name="com.civifix.utils.AnnotationTransformer" />
        <listener class-name="com.civifix.utils.TestListener" />
    </listeners>

    <test name="End-to-End Tests">
        <classes>
            <class name="com.civifix.tests.e2e.ComplaintWorkflowTest" />
        </classes>
    </test>
    
    <test name="Negative Tests">
        <classes>
            <class name="com.civifix.tests.negative.LoginNegativeTest" />
        </classes>
    </test>
    
    <test name="Security &amp; Vulnerability Tests">
        <classes>
            <class name="com.civifix.tests.security.InputValidationTest" />
        </classes>
    </test>
</suite>
